# Archer/Quiver sshd_config — sensor-facing only.
#
# This sshd accepts only one form of traffic: a Quiver sensor pushing logs
# via rsync, authenticated by an ed25519 keypair generated at enrollment.
# Every authorized_keys line carries a per-sensor command="rsync --server ...
# /logs/<name>/" plus no-pty / no-port-forwarding / no-X11 restrictions, so a
# leaked sensor key can do exactly one thing: write that sensor's logs.

Port 22

# Host keys live in a persistent volume so sensors don't see
# host-key-mismatch warnings after a container rebuild. The entrypoint
# generates them on first boot.
HostKey /etc/ssh/keys/ssh_host_ed25519_key
HostKey /etc/ssh/keys/ssh_host_rsa_key

# Hard-disable everything except pubkey auth.
PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PermitEmptyPasswords no
UsePAM no
PubkeyAuthentication yes
# authorized_keys is written by the non-root archer process (uid 1001),
# so it is not owned by quiver. StrictModes no skips the ownership check.
StrictModes no

# Only the quiver user is allowed in. Per-sensor authorized_keys entries
# pin each connection to its own rsync target.
AllowUsers quiver
AuthorizedKeysFile /home/quiver/.ssh/authorized_keys

# Don't expose any ancillary services. SFTP could be useful for debugging
# but isn't part of the sensor protocol; leave it off.
AllowTcpForwarding no
AllowAgentForwarding no
X11Forwarding no
PermitTunnel no
GatewayPorts no
PrintMotd no

LogLevel INFO
PidFile /run/sshd.pid
