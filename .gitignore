# Generated by start.sh — machine-specific resource limits, may contain API keys
.env
.env.*

# Zeek log datasets — network captures are never committed
logs/*
!logs/.gitkeep

# SQLite database if running the binary directly on the host (outside Docker)
data/
*.db
*.sqlite

# Compiled binaries
/archer
/archer.exe

# macOS
.DS_Store

# Editor and IDE directories
.idea/
.vscode/
*.swp
*.swo

# Private operator's logbook — durable maturation roadmap, not for the public repo
MATURATION_PLAN.md

# Private AI-assistant onboarding doc — operator voice, conventions, lessons learned
CLAUDE.md
